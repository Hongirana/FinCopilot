# Database Configuration (same style as your .env)
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_TEST_NAME=fincopilot_test

# JWT Secret
JWT_SECRET_KEY=test-secret-key-fincopilot-2026

# Environment
NODE_ENV=test

# Server Port
PORT=5001

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fincopilot_db_test?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
#REDIS_PASSWORD= 
REDIS_TTL=3600  # Default cache TTL in seconds (1 hour)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

WSL_PASSWOD = 12345

