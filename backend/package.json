{
  "name": "fincopilot-project",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:verbose": "cross-env NODE_ENV=test jest --verbose",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:db:push": "dotenv -e .env.test -- npx prisma db push",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:test": "cross-env DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/fincopilot_db_test\" npx prisma migrate deploy",
    "migrate:prod": "npx prisma migrate deploy",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "postinstall": "npx prisma generate",
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
